FROM php:8.4-cli

WORKDIR /var/www/html

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    libpng-dev \
    libonig-dev \
    libxml2-dev \
    zip \
    unzip \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Install PHP extensions (no opcache for dev)
RUN docker-php-ext-install mbstring exif pcntl bcmath gd sockets pdo pdo_mysql pdo_pgsql

# Install Redis extension
RUN pecl install redis && docker-php-ext-enable redis

# Install Composer
RUN php -r "copy('https://getcomposer.org/installer', 'composer-setup.php');" \
 && php composer-setup.php --install-dir=/usr/local/bin --filename=composer \
 && rm composer-setup.php

# Copy and install Laravel deps
COPY backend/composer.json backend/composer.lock ./
RUN composer install --no-dev --optimize-autoloader --no-scripts

# Copy full Laravel app
COPY backend/ .

# Generate application key
RUN php artisan key:generate --force

EXPOSE 9000

# php artisan serve auto-reloads on file change
CMD ["php", "artisan", "serve", "--host=0.0.0.0", "--port=9000"]
