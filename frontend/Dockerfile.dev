FROM node:20-alpine

WORKDIR /app

# Install dependencies first (cached layer)
COPY package*.json ./
RUN npm install

# Copy source (volume will override for dev)
COPY . .

# Expose Vite dev server port
EXPOSE 5173

# Vite dev server with HMR — listens on all interfaces for docker networking
CMD ["npx", "vite", "--host", "0.0.0.0", "--port", "5173"]
